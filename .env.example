COUCHDB_USER=app
COUCHDB_PASSWORD=app
# echo -n 'user:password' | base64 — must match COUCHDB_USER:COUCHDB_PASSWORD (default app:app = YXBwOmFwcA==)
COUCHDB_APP_B64=YXBwOmFwcA==

# Browser login when opening /couchdb/_utils/ (Fauxton). Defaults match CouchDB: app / app.
FAUXTON_BASIC_USER=app
FAUXTON_BASIC_PASSWORD=app

NGINX_SERVER_NAME=fielddb.roualdes.us
FRONTEND_PORT=80
PUBLIC_URL=/


REACT_APP_BUILD_REF=
